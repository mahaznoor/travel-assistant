# ─────────────────────────────────────────────────────────────
#  Rahbar – Smart Travel Companion Agent  |  .env.example
#  Copy this file:  cp .env.example .env
#  Then fill in your free API keys below.
# ─────────────────────────────────────────────────────────────

# 1. Gemini API — FREE (15 req/min)
#    Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. OpenWeatherMap — FREE (60 req/min)
#    Get key: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweathermap_key_here

# 3. AviationStack — FREE tier (100 req/month) — OPTIONAL
#    Without this key, demo flight data is used automatically.
#    Get key: https://aviationstack.com/signup/free
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# 4. Server settings (change only if needed)
FRONTEND_URL=http://localhost:5173
